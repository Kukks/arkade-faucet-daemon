PORT=8080
ARK_SERVER_URL=https://mutinynet.arkade.sh
IS_MAINNET=false
# ESPLORA_URL=            # optional on-chain data source; unset uses the SDK default for the network
DB_PATH=/data/arkade-wallet.sqlite
ARKADE_MNEMONIC=

# Optional shared secret. When set, POST /send requires header X-Internal-Token: <value>.
# Leave unset if the daemon is only reachable on a trusted internal network.
# INTERNAL_TOKEN=

# Optional auto-replenishment. Leave both unset to disable.
# FAUCET_API=https://faucet.mutinynet.com
# FAUCET_API_TOKEN=       # full Authorization header value (e.g. "Bearer …" or "L402 …")

MIN_BALANCE=100000
REPLENISH_AMOUNT=1000000
MAX_SEND=100000
ALLOWED_ORIGIN=*
REPLENISH_INTERVAL_MS=30000
